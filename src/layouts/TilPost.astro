---
import type { CollectionEntry } from 'astro:content';
import Badge from '@components/Badge.astro';
import JsonLd from '@components/JsonLd.astro';
import PostMeta from '@components/PostMeta.astro';
import { createSiteContent } from '@lib/content/siteContent';
import { articlePostingSchema } from '@lib/seo/jsonLd';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'til'>['data'] & {
  next?: CollectionEntry<'til'>;
  prev?: CollectionEntry<'til'>;
  slug?: string;
};

const {
  title,
  date,
  lastmod,
  next,
  prev,
  tags,
  categories,
  slug,
  question,
  summary,
  description,
  author,
  authorUrl,
} = Astro.props;
const content = createSiteContent();

if (!slug) {
  throw new Error('TilPost component requires a slug prop');
}

const metaDescription =
  description ?? summary ?? tags?.join(', ') ?? '';

const structuredData = articlePostingSchema({
  site: Astro.site,
  collectionPath: '/til/',
  schemaType: 'Article',
  slug,
  title,
  description: metaDescription,
  date,
  lastmod,
  tags,
  categories,
  authorName: author,
  authorUrl,
});
---

<BaseLayout title={title} description={metaDescription}>
  <JsonLd data={structuredData} />
  <article class="prose text-xl dark:prose-invert">
    <div class="w-full max-w-4xl mx-auto px-3 text-foreground">
      <div class="py-2 line-height-1 flex flex-col gap-2">
        <h1 class="text-foreground text-4xl mb-0">{title}</h1>
        <PostMeta
          author={author}
          authorUrl={authorUrl}
          date={date}
          lastmod={lastmod}
        />
        {question && (
          <h2 class="text-xl font-medium not-prose text-foreground mt-2 mb-0">
            {question}
          </h2>
        )}
        {summary && (
          <p class="text-lg not-prose text-prose-caption leading-relaxed mt-2 mb-0">
            {summary}
          </p>
        )}
        <div class="flex gap-3 items-center">
          {tags.map((tag) => (
              <Badge link={content.taxonomy('tag', tag, 'til').href}>{tag}</Badge>
            ))}
        </div>
        <hr class="mt-5 mb-0" />
      </div>
      <slot />
    </div>
  </article>

  <hr class="my-8 border-slate-300 dark:border-slate-700" />

  <div class="flex justify-between w-2xl max-w-4xl mx-auto p-3 gap-8 text-brand-100">
    {prev && (
        <a
          href={content.url(prev).href}
          class="flex gap-2 items-center transition-color duration-200 hover:text-brand-200"
        >
          <span>{`< `}</span> {prev.data.title}
        </a>
      )}
    {next && (
        <a
          href={content.url(next).href}
          class="flex gap-2 items-center transition-color duration-200 hover:text-brand-200"
        >
          {next.data.title} <span>{` >`}</span>
        </a>
      )}
  </div>
</BaseLayout>
