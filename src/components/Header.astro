---
import { Image } from 'astro:assets';
import { NAV_LINKS } from '@lib/constants';
import { cn } from '@lib/utils';
import { Menu, X } from 'lucide-astro';
import HeaderLink from './HeaderLink.astro';
import ThemeSwitch from './ThemeSwitch.astro';
---

<header
  class={cn(
    // spacing
    "m-0 p-3 max-h-[70px] md:max-h-[90px]",
    // background
    "bg-orange-50 dark:bg-slate-900",
    // text
    "text-black dark:text-white",
    // shadow
    "shadow-md",
    // border top
    "border-t-[6px] border-t-brand-100",
    // border bottom
    "border-b-2 border-b-slate-200 dark:border-b-slate-700",
  )}
>
  <nav>
    <div class="flex flex-wrap items-center justify-between mx-auto w-full max-w-3xl">
      <a
        href="/"
        class="flex items-center w-[150px] lg:w-[180px] h-[38px] lg:h-[45px]"
        aria-label="joelmturner logo"
      >
        <Image
          data-logo
          width="180"
          height="45"
          src={`https://res.cloudinary.com/joelmturner/image/upload/c_scale,w_360,f_auto,q_auto/v1673573341/jmt-logo-dark-500w_2_pxay5e.png`}
          alt="joelmturner logo"
          class="w-full h-full object-contain"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
          style="aspect-ratio: 4/1;"
        />
      </a>
      <button
        type="button"
        data-nav-drawer-trigger
        class="btn btn-ghost btn-sm md:hidden"
        title="Open navigation menu"
      >
        <Menu size={18} aria-hidden="true" />
      </button>
      <div class="hidden w-full md:block md:w-auto" id="navbar-default">
        <ul
          class="font-medium flex flex-col p-4 md:p-0 md:flex-row md:m-0 md:border-0 md:gap-2 mt-4 border border-slate-100 dark:border-slate-700 rounded-lg bg-transparent"
        >
          {NAV_LINKS.map(link =>
              link.children ? (
                <li class="group relative">
                  <HeaderLink
                    href={link.href}
                    aria-current="page"
                    aria-haspopup="true"
                  >
                    {link.label}
                  </HeaderLink>
                  <ul
                    class={cn(
                      "absolute -left-1 top-full pt-1 min-w-40 pl-2 flex flex-col gap-1 z-10",
                      "opacity-0 invisible transition-opacity duration-150",
                      "group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible",
                      "bg-orange-50 dark:bg-slate-900 rounded-md shadow-md border border-slate-200 dark:border-slate-700 py-1",
                    )}
                  >
                    {link.children.map(child => (
                      <li>
                        <HeaderLink
                          href={child.href}
                          aria-current="page"
                          hideActiveBorder={true}
                          class="block py-2 rounded-none border-b-0! hover:border-b-0!"
                        >
                          {child.label}
                        </HeaderLink>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li>
                  <HeaderLink href={link.href} aria-current="page">
                    {link.label}
                  </HeaderLink>
                </li>
              ),
            )}
          <ThemeSwitch />
        </ul>
      </div>
    </div>
  </nav>
</header>

<wa-drawer data-nav-drawer-content class="hidden">
  <button
    slot="header"
    type="button"
    data-drawer="close"
    class="btn btn-ghost btn-sm ml-auto"
    aria-label="Close navigation menu"
  >
    <X size={16} aria-hidden="true" />
  </button>
  <div class="flex flex-col gap-2 md:hidden">
    <ul class="font-medium text-xl flex flex-col gap-1">
      {NAV_LINKS.map(link =>
          link.children ? (
            <li class="flex flex-col">
              <HeaderLink
                href={link.href}
                aria-current="page"
                hideActiveBorder={true}
              >
                {link.label}
              </HeaderLink>
              <ul class="flex flex-col gap-1 pl-2">
                {link.children.map(child => (
                  <li>
                    <HeaderLink
                      href={child.href}
                      aria-current="page"
                      hideActiveBorder={true}
                    >
                      {child.label}
                    </HeaderLink>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <HeaderLink href={link.href} aria-current="page">
                {link.label}
              </HeaderLink>
            </li>
          ),
        )}
      <div class="flex mx-auto w-3/4"><ThemeSwitch /></div>
    </ul>
  </div>
</wa-drawer>

<style>
::part(header) {
  border-top: 6px solid var(--color-brand-100);
}
::part(close-button) {
  position: absolute;
  top: 1rem;
  right: 1rem;
}
</style>

<script is:inline>
// set up drawer event listener on each page load
// using is:inline ensures this runs immediately when the page loads
(() => {
  const drawer = document.querySelector('[data-nav-drawer-content]');
  const openButton = document.querySelector('[data-nav-drawer-trigger]');

  if (openButton && drawer) {
    openButton.addEventListener('click', () => {
      if (drawer && 'open' in drawer) {
        drawer.open = true;
        drawer.classList.remove('hidden');
        drawer.classList.add('block');
      }
    });
  }
})();
</script>
