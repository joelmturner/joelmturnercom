---
import { cn } from '@lib/utils';

const { variant, height = '500px', width = '100%', size = 'medium', ...rest } = Astro.props;
const style = variant === 'card' ? '--canvas-padding: 0;' : '';
---

<div
  class={cn('flex flex-col gap-4 ', size === 'medium' ? 'h-[500px] mb-4' : 'h-[250px] mb-1')}
  style={`height: ${height}; width: ${width};`}
>
  <zine-viewer id={variant} style={style} {...rest}> <slot /> </zine-viewer>
</div>

<script
  is:inline
  type="module"
  src="https://unpkg.com/@joelmturner/zine-viewer-web-component?module"
></script>

<style>
zine-viewer {
  --canvas-bg-color: rgba(81, 77, 86, 0.5);
}
</style>
