---
import { Font } from 'astro:assets';
import PostHog from '@components/PostHog.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@lib/site';
import { getCldOgImageUrl } from 'astro-cloudinary/helpers';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** e.g. "noindex, follow" for tag archives; omit for default index,follow */
  robots?: string;
  /** when set, og:type is article and article:* tags are emitted */
  openGraphArticle?: {
    publishedTime: string;
    modifiedTime?: string;
    authorUrl?: string;
  };
}

// ensure canonical URL has trailing slash (except root) to match trailingSlash: "always" config
const pathname =
  Astro.url.pathname === '/'
    ? '/'
    : Astro.url.pathname.endsWith('/')
      ? Astro.url.pathname
      : `${Astro.url.pathname}/`;
const canonicalURL = new URL(pathname, Astro.site);

function isValidURL(url: string) {
  const urlPattern = /^(https?|ftp):\/\/[^\s/$.?#].[^\s]*$/i;
  return urlPattern.test(url);
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = 'https://res.cloudinary.com/joelmturner/image/upload/h_630,w_1200/c_fit,h_400,l_text:Helvetica_80_bold_line_spacing_20:Digital%20Adventurer%20and%20Illustrator,w_700/fl_layer_apply,g_west,x_400,y_0/blog-post-card.png',
  robots,
  openGraphArticle,
} = Astro.props;

const ogType = openGraphArticle ? 'article' : 'website';

const ogImage = isValidURL(image)
  ? image
  : getCldOgImageUrl({
      src: image,
      width: 1200,
      height: 630,
      crop: 'fill',
      format: 'jpg',
      quality: 'auto',
      gravity: 'center',
    });

const resolvedTitle = title ? `${title} | ${SITE_TITLE}` : `${SITE_TITLE} Web Development Blog`;
---

<!-- Global Metadata - placed early to ensure CSS loads first -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- DNS prefetch for faster connections (lightweight hints for less critical origins) -->
<link rel="dns-prefetch" href="https://us.i.posthog.com" />
<link rel="dns-prefetch" href="https://us-assets.i.posthog.com" />
<link rel="dns-prefetch" href="https://gc.zgo.at" />
<link rel="dns-prefetch" href="https://o556640.ingest.sentry.io" />

<!-- Theme initialization - must run before page renders to prevent flash -->
<script is:inline>
(() => {
  try {
    const theme = localStorage.getItem('theme');
    const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
      ? 'dark'
      : 'light';
    const colorMode = theme === 'system' || !theme ? systemTheme : theme;
    document.documentElement.setAttribute('data-color-mode', colorMode);
    if (colorMode === 'dark') {
      document.documentElement.classList.add('wa-dark');
    } else {
      document.documentElement.classList.remove('wa-dark');
    }
  } catch (e) {
    // fallback to system theme if localStorage is not available
    const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
      ? 'dark'
      : 'light';
    document.documentElement.setAttribute('data-color-mode', systemTheme);
    if (systemTheme === 'dark') {
      document.documentElement.classList.add('wa-dark');
    } else {
      document.documentElement.classList.remove('wa-dark');
    }
  }
})();
</script>
<link rel="icon" type="image/png" href="/favicon-32x32.png" />
<meta name="generator" content={Astro.generator} />

<!-- Preconnect to critical third-party domains (max 4 for best performance) -->
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://ka-p.webawesome.com" crossorigin />
<link rel="preconnect" href="https://res.cloudinary.com" crossorigin />

<!-- Prefetch non-critical resources for faster subsequent loads -->
<link rel="dns-prefetch" href="https://www.youtube.com" />
<link rel="dns-prefetch" href="https://i.ytimg.com" />

<!-- preload critical hero image on home page -->
{import.meta.env.PROD && Astro.url.pathname === "/" && (
    <link
      rel="preload"
      as="image"
      href="https://res.cloudinary.com/joelmturner/image/upload/c_fill,h_200,w_200,g_faces,dpr_2.0/joel-turner_nobg"
      fetchpriority="high"
    />
  )}

<!-- Web Awesome - defer loading to avoid blocking render -->
<script
  is:inline
  src="https://kit.webawesome.com/2dafcc2cf8fd4a26.js"
  crossorigin="anonymous"
  defer
></script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href="/sitemap-index.xml" />
{robots && <meta name="robots" content={robots} />}

<!-- Primary Meta Tags -->
<title>{resolvedTitle}</title>
<meta name="title" content={resolvedTitle} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${ogImage}?v=1`} />
<meta property="og:image:secure_url" content={`${ogImage}?v=1`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{openGraphArticle && (
    <>
      <meta
        property="article:published_time"
        content={openGraphArticle.publishedTime}
      />
      {openGraphArticle.modifiedTime && (
        <meta
          property="article:modified_time"
          content={openGraphArticle.modifiedTime}
        />
      )}
      {openGraphArticle.authorUrl && (
        <meta property="article:author" content={openGraphArticle.authorUrl} />
      )}
    </>
  )}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={resolvedTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={`${ogImage}?v=1`} />

<link rel="webmention" href="https://webmention.io/joelmturner.com/webmention" />
<link rel="pingback" href="https://webmention.io/joelmturner.com/xmlrpc" />

<script
  is:inline
  data-goatcounter="https://joelmturner.goatcounter.com/count"
  defer
  src="//gc.zgo.at/count.js"
></script>

<Font cssVariable="--font-fira-code" preload />
<Font cssVariable="--font-fira-sans" preload />

<!-- analytics -->
{import.meta.env.MODE !== "development" && <PostHog />}
