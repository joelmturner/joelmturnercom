---
type Props = {
  link?: string;
};

const { link } = Astro.props;
---

{link ? (
    <a href={link} class="btn btn-outline btn-sm border-brand-200 dark:border-brand-300">
      <slot />
    </a>
  ) : (
    <span
      class="inline-flex items-center rounded-md border border-brand-200 dark:border-brand-300 px-2 py-1 text-sm"
    >
      <slot />
    </span>
  )}
