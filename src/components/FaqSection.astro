---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section aria-labelledby="faq-heading" class="not-prose mt-10">
  <h2 id="faq-heading" class="text-2xl font-bold mb-4">FAQ</h2>
  <div class="flex flex-col gap-6">
    {items.map((item) => (
      <article>
        <h3 class="text-xl font-semibold mb-2">{item.question}</h3>
        <p class="text-base leading-relaxed">{item.answer}</p>
      </article>
    ))}
  </div>
</section>
