---
---

<dialog
  data-zine-dialog
  class="m-auto w-full max-w-[560px] rounded-lg border border-slate-200 p-0 dark:border-slate-700 dark:bg-slate-900"
>
  <div class="flex justify-end p-2">
    <button type="button" class="btn btn-ghost btn-sm" data-zine-dialog-close aria-label="Close">
      Close
    </button>
  </div>
  <iframe
    class="w-full max-w-[560px] h-full min-h-[315px]"
    src="https://www.youtube.com/embed/llhMYmG0PCg?si=xfim2gsSCW7EQbXO&start=130"
    title="YouTube video player"
    allow="
      accelerometer;
      autoplay;
      clipboard-write;
      encrypted-media;
      gyroscope;
      picture-in-picture;
      web-share;
    "
    referrerpolicy="strict-origin-when-cross-origin"
    allowfullscreen
  ></iframe>
</dialog>

<button type="button" class="btn btn-soft btn-sm btn-accent" data-zine-dialog-open>
  <span aria-hidden="true">i</span>
  How to fold one page zines
</button>

<script>
const dialog = document.querySelector('[data-zine-dialog]');
const openButton = document.querySelector('[data-zine-dialog-open]');
const closeButton = document.querySelector('[data-zine-dialog-close]');

openButton?.addEventListener('click', () => {
  if (dialog instanceof HTMLDialogElement) {
    dialog.showModal();
  }
});

closeButton?.addEventListener('click', () => {
  if (dialog instanceof HTMLDialogElement) {
    dialog.close();
  }
});
</script>

<style>
[data-zine-dialog]::backdrop {
  background: rgb(15 23 42 / 0.55);
}
</style>
