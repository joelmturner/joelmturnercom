---
import Badge from '@components/Badge.astro';
import GridLayout from '@components/GridLayout.astro';
import LinkButton from '@components/LinkButton.astro';
import Prose from '@components/Prose.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { createSiteContent } from '@lib/content/siteContent';

const content = createSiteContent();
const tilPosts = await content.list('til');
---

<BaseLayout
  title={'Dev Tips'}
  description="Things I've learned: Astro, React, TypeScript, tooling, and front-end development tips."
>
  <section>
    <GridLayout title="Dev Tips">
      {tilPosts.map((post) => (
          <div class="flex flex-col">
            <Prose className="prose-xl">
              <h3>
                <LinkButton href={content.url(post).href}>{post.data.title}</LinkButton>
              </h3>
              <div class="flex gap-3 items-center">
                {post.data.tags.map((tag) => (
                  <Badge link={content.taxonomy('tag', tag, 'til').href}>{tag}</Badge>
                ))}
              </div>
            </Prose>
          </div>
        ))}
    </GridLayout>
  </section>
</BaseLayout>
