---
import { getCollection } from 'astro:content';
import LinkButton from '@components/LinkButton.astro';
import PageTitle from '@components/PageTitle.astro';
import ZineCard from '@components/ZineCard.astro';
import ZineFoldInstructions from '@components/ZineFoldInstructions.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { ArrowLeft } from 'lucide-astro';

const zines = await getCollection('zines');
---

<BaseLayout title={"Zines"} description={"Some illustrative zines"}>
  <div class="flex justify-between items-center mb-8">
    <PageTitle title="Illustrated zines" />
    <LinkButton href="/illustration/" class="flex gap-2 items-center"
      ><ArrowLeft size={16} aria-hidden="true" />
      Back to Illustrations</LinkButton
    >
  </div>

  <div class="flex gap-2"><ZineFoldInstructions /></div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-8 h-full pb-[120px]">
    {zines.map(zine => <ZineCard zine={zine} />)}
  </div>
</BaseLayout>
